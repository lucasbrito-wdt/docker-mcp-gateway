# =============================================
# Docker MCP Gateway — Environment Variables
# =============================================

# REQUIRED: Bearer token for MCP authentication
# Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=your-super-secret-token-minimum-32-chars-here

# OPTIONAL: Comma-separated list of allowed IPs for Nginx whitelist
# Leave empty to allow all IPs (not recommended for production)
# Example: ALLOWED_IPS=1.2.3.4,5.6.7.8
ALLOWED_IPS=

# OPTIONAL: Colon-separated list of allowed host paths for docker compose tools
# Example: COMPOSE_PROJECT_PATH_WHITELIST=/opt/myapp:/opt/otherapp
COMPOSE_PROJECT_PATH_WHITELIST=
